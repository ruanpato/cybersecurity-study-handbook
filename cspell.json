{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en,pt,pt-BR",
  "import": ["@cspell/dict-pt-br/cspell-ext.json"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": ".cspell/project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["software-terms", "project-words"],
  "ignorePaths": [
    ".git/**",
    "node_modules/**",
    ".internal/**",
    "site/**",
    "site-src/**",
    ".cspell/**",
    "package-lock.json",
    "CHANGELOG.md",
    "*.cff"
  ],
  "ignoreRegExpList": ["Urls", "Email", "/`[^`]+`/", "/```[\\s\\S]*?```/"]
}
