# Normalize line endings to LF across platforms.
* text=auto eol=lf

# Binary assets (never normalize).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.ico  binary

# Keep GitHub language stats representative of the content (Markdown),
# not the small tooling configs.
commitlint.config.js linguist-detectable=false
.husky/**            linguist-vendored
package-lock.json    linguist-generated

*.md linguist-detectable=true
*.sh linguist-detectable=false
